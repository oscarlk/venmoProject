# Google OAuth client credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret for signing Flask session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# --- Production only -------------------------------------------------------
# URL of the deployed frontend (used for CORS + OAuth popup postMessage).
# Local dev defaults to http://localhost:5173 if unset.
FRONTEND_URL=

# OAuth redirect URI registered in Google Cloud Console. Local dev defaults to
# http://localhost:8000/auth/callback/google if unset.
GOOGLE_REDIRECT_URI=

# MongoDB Atlas connection string. If set, Gmail tokens are stored in MongoDB
# instead of local files. Leave unset for local file-based dev.
MONGODB_URI=
MONGODB_DB=venmo

# Set to "false" in production to disable the Flask debugger.
FLASK_DEBUG=true

# Secret for the admin-only /admin/diagnose debug endpoint. If unset, the
# endpoint is disabled (returns 403). Generate like FLASK_SECRET_KEY.
ADMIN_KEY=
